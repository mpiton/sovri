# Sovri — pnpm configuration.
# pnpm is locked as the sole package manager (see docs/adr/002).
# Security flags below mitigate npm supply-chain attacks (e.g. malicious
# lifecycle scripts).

# Refuse to install or run if Node/pnpm versions are out of `engines` range.
engine-strict=true

# Refuse to run lifecycle scripts (preinstall/install/postinstall) from any
# dependency. Protects against mini-shai-hulud-style supply chain attacks.
# Allowlist must be added explicitly via `pnpm.onlyBuiltDependencies` in
# package.json when a trusted package legitimately needs build steps.
ignore-scripts=true

# Auto-install peer dependencies (pnpm 10 default behavior, made explicit).
auto-install-peers=true

# Strict peer dependency resolution: fail install on missing/invalid peers
# instead of silently warning.
strict-peer-dependencies=true

# Save exact versions by default (no caret/tilde). Reinforces the pinning
# discipline required for LLM SDKs and security-sensitive deps.
save-exact=true

# Verify package integrity using the lockfile's SHA-512 checksums.
verify-store-integrity=true
