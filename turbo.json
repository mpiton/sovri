{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".npmrc", "pnpm-workspace.yaml"],
  "globalPassThroughEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "tsconfig*.json", "package.json"],
      "outputs": ["dist/**", ".tsbuildinfo", "*.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "test/**",
        "tests/**",
        "vitest.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "test/**",
        "tests/**",
        "package.json",
        "tsconfig*.json"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "test/**",
        "tests/**",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": ["*.tsbuildinfo", ".tsbuildinfo"]
    }
  }
}
