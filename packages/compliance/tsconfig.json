{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./.tsbuild",
    "emitDeclarationOnly": true,
    "types": ["node"]
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["dist", ".tsbuild", "node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
