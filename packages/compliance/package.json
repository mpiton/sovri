{
  "name": "@sovri/compliance",
  "version": "0.10.1",
  "private": true,
  "description": "Sovri compliance mapping and audit trail foundations.",
  "homepage": "https://github.com/mpiton/sovri/tree/main/packages/compliance#readme",
  "bugs": {
    "url": "https://github.com/mpiton/sovri/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpiton/sovri.git",
    "directory": "packages/compliance"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --root . --passWithNoTests",
    "lint": "oxlint . --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@sovri/core": "workspace:*",
    "js-yaml": "4.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.2",
    "tsup": "8.5.1",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=24.17.0 <25.0.0",
    "pnpm": ">=10.34.4 <11.0.0"
  }
}
