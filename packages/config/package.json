{
  "name": "@sovri/config",
  "version": "0.9.0",
  "private": true,
  "description": "Sovri config — `.sovri.yml` parser and validator. v0.1 ships only the package scaffold; full schema and loader land in follow-up tasks (ADR-005, ADR-010).",
  "homepage": "https://github.com/mpiton/sovri/tree/main/packages/config#readme",
  "bugs": {
    "url": "https://github.com/mpiton/sovri/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpiton/sovri.git",
    "directory": "packages/config"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --root . --passWithNoTests",
    "lint": "oxlint . --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@sovri/core": "workspace:*",
    "@sovri/observability": "workspace:*",
    "js-yaml": "4.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.4",
    "tsup": "8.5.1",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=24.8.0 <25.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  }
}
