{
  "name": "@sovri/review-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Sovri review orchestration engine — diff, prompts, LLM parsing, walkthrough composition, and orchestration.",
  "homepage": "https://github.com/mpiton/sovri/tree/main/packages/review-engine#readme",
  "bugs": {
    "url": "https://github.com/mpiton/sovri/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpiton/sovri.git",
    "directory": "packages/review-engine"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --root . --passWithNoTests",
    "lint": "oxlint . --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@sovri/core": "workspace:*",
    "@sovri/llm-providers": "workspace:*",
    "@sovri/observability": "workspace:*",
    "parse-diff": "0.12.0",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "msw": "2.14.6",
    "tsup": "8.5.1",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24.8.0 <25.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  }
}
