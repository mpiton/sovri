{
  "name": "@sovri/llm-providers",
  "version": "0.3.0",
  "private": true,
  "description": "Sovri LLM provider adapters — BYOK. v0.1 ships Anthropic structured-output support.",
  "homepage": "https://github.com/mpiton/sovri/tree/main/packages/llm-providers#readme",
  "bugs": {
    "url": "https://github.com/mpiton/sovri/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpiton/sovri.git",
    "directory": "packages/llm-providers"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --root . --passWithNoTests",
    "lint": "oxlint . --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.99.0",
    "@mistralai/mistralai": "2.2.5",
    "@sovri/config": "workspace:*",
    "@sovri/core": "workspace:*",
    "@sovri/observability": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "msw": "2.14.6",
    "tsup": "8.5.1",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=24.8.0 <25.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  }
}
