{
  "name": "sovri",
  "version": "0.0.0",
  "private": true,
  "description": "Sovri — EU-sovereign AI code review platform for regulated enterprises.",
  "homepage": "https://github.com/mpiton/sovri#readme",
  "bugs": {
    "url": "https://github.com/mpiton/sovri/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpiton/sovri.git"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "oxlint . --max-warnings=0 --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --no-error-on-unmatched-pattern",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "knip": "knip --reporter compact",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "knip": "6.13.1",
    "lefthook": "2.1.6",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "turbo": "2.9.12",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24.8.0 <25.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
