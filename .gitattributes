# Default: detect text vs binary, normalize line endings to LF on commit.
* text=auto eol=lf

# Force LF for source + config — never CRLF, even on Windows checkouts.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sh        text eol=lf
*.toml      text eol=lf

# Lockfile + generated artifacts: marked linguist-generated so GitHub collapses
# the diff by default and excludes them from language stats. Textual diffs stay
# enabled — reviewers must be able to read dependency changes to catch
# malicious or unexpected modifications.
pnpm-lock.yaml          linguist-generated=true
sbom.json               linguist-generated=true
*.sbom.json             linguist-generated=true
*.cyclonedx.json        linguist-generated=true

# Binary assets — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
