{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,js,mjs}", "*.config.{ts,js,mjs}"],
      "project": ["**/*.{ts,tsx,mts,cts,js,mjs,cjs}!"],
      "ignoreBinaries": ["oxlint", "oxfmt", "knip", "turbo", "tsc"]
    },
    "packages/*": {
      "entry": ["src/index.ts!", "src/{cli,bin,server,worker}.ts!"],
      "project": ["src/**/*.{ts,tsx,mts}!"]
    },
    "packages/observability": {
      "entry": ["src/index.ts!", "src/{cli,bin,server,worker}.ts!"],
      "project": ["src/**/*.{ts,tsx,mts}!"],
      "ignoreDependencies": [
        "pino-pretty",
        "@opentelemetry/api",
        "@opentelemetry/auto-instrumentations-node",
        "@opentelemetry/exporter-prometheus",
        "@opentelemetry/exporter-trace-otlp-http",
        "@opentelemetry/instrumentation-pino",
        "@opentelemetry/resources",
        "@opentelemetry/sdk-metrics",
        "@opentelemetry/sdk-node",
        "@opentelemetry/semantic-conventions"
      ]
    },
    "packages/config": {
      "entry": ["src/index.ts!", "src/{cli,bin,server,worker}.ts!"],
      "project": ["src/**/*.{ts,tsx,mts}!"],
      "ignoreDependencies": ["zod"]
    },
    "packages/compliance": {
      "entry": ["src/index.ts!", "src/{cli,bin,server,worker}.ts!"],
      "project": ["src/**/*.{ts,tsx,mts}!"],
      "ignoreDependencies": ["@sovri/core", "zod"]
    },
    "packages/llm-providers": {
      "entry": ["src/index.ts!", "src/{cli,bin,server,worker}.ts!"],
      "project": ["src/**/*.{ts,tsx,mts}!"],
      "ignoreDependencies": ["@anthropic-ai/sdk", "@mistralai/mistralai", "openai", "zod"]
    },
    "apps/*": {
      "entry": ["src/index.ts!", "src/{server,main,bin,worker}.ts!", "tests/**/*.test.ts!"],
      "project": ["src/**/*.{ts,tsx,mts}!", "tests/**/*.{ts,tsx,mts}!"]
    }
  },
  "ignore": [
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/.cache/**",
    "**/.worktrees/**",
    "**/node_modules/**"
  ],
  "ignoreDependencies": ["lefthook"],
  "ignoreExportsUsedInFile": true
}
