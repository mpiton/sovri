{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "env": {
    "builtin": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "typescript/ban-ts-comment": [
      "error",
      {
        "ts-ignore": true,
        "ts-expect-error": true,
        "ts-nocheck": true,
        "ts-check": false,
        "minimumDescriptionLength": 0
      }
    ],
    "typescript/no-non-null-assertion": "error",
    "eqeqeq": ["error", "always"],
    "no-console": "warn",
    "import/no-unassigned-import": ["error", { "allow": ["**/instrumentation.js"] }]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.spec.ts", "**/tests/**", "**/__tests__/**"],
      "rules": {
        "typescript/no-non-null-assertion": "off",
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/.cache/**",
    "**/*.min.js",
    "**/.worktrees/**"
  ]
}
